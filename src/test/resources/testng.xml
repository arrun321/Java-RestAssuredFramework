<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestAssured API Test Suite" verbose="1" parallel="none">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Smoke Tests" preserve-order="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.restassured.framework.tests.UserTests">
                <methods>
                    <include name="getAllUsers_shouldReturn200WithUserList"/>
                    <include name="getUserById_shouldReturn200WithCorrectUser"/>
                </methods>
            </class>
            <class name="com.restassured.framework.tests.PostTests">
                <methods>
                    <include name="getAllPosts_shouldReturn200WithPostList"/>
                    <include name="getPostById_shouldReturn200WithCorrectPost"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="Regression Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.tests.UserTests"/>
            <class name="com.restassured.framework.tests.PostTests"/>
            <class name="com.restassured.framework.tests.CommentTests"/>
        </classes>
    </test>

    <!-- BDD Cucumber Tests -->
    <test name="BDD Cucumber Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.bdd.runner.CucumberRunner"/>
        </classes>
    </test>

    <!-- Course Enrollment API Tests -->
    <test name="CE Status Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.tests.StatusTest"/>
        </classes>
    </test>

    <test name="CE Course Management Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.tests.CourseManagementTests"/>
        </classes>
    </test>

    <test name="CE User Journey Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.tests.UserJourneyTest"/>
        </classes>
    </test>

</suite>
