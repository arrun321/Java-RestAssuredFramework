<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="BDD Cucumber Suite" verbose="1" parallel="none">

    <!--
        Use this suite when running Cucumber scenarios with tag filters.
        The cucumber.filter.tags system property applies only to the CucumberRunner
        and has no effect on TestNG test classes.

        Examples:
          mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-cucumber.xml "-Dcucumber.filter.tags=@smoke"
          mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-cucumber.xml "-Dcucumber.filter.tags=@status"
          mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-cucumber.xml "-Dcucumber.filter.tags=@journey"
          mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-cucumber.xml "-Dcucumber.filter.tags=@courses"
    -->

    <test name="BDD Cucumber Tests" preserve-order="true">
        <classes>
            <class name="com.restassured.framework.bdd.runner.CucumberRunner"/>
        </classes>
    </test>

</suite>
